{
  "compilerOptions": {
    "outDir": "dist",
    "target": "es2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "dist",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "types": []
  },
  "include": ["src", "mocks"]
}
